# Appwrite authentication and private file storage
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
# Used only by the one-time legacy Appwrite notes migration script.
APPWRITE_DATABASE_ID=vio-database
APPWRITE_FILES_BUCKET_ID=files
APPWRITE_IMAGES_BUCKET_ID=images
APPWRITE_VIDEOS_BUCKET_ID=videos
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_FILES_BUCKET_ID=files
NEXT_PUBLIC_APPWRITE_IMAGES_BUCKET_ID=images
NEXT_PUBLIC_APPWRITE_VIDEOS_BUCKET_ID=videos
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TiDB
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=vio_database
TIDB_SSL=true

# Internal AI services (server-only)
AGENT_SERVICE_URL=http://localhost:8081
AGENT_SERVICE_REQUIRE_OIDC=false
AGENT_SERVICE_OIDC_AUDIENCE=
AGENT_SHARED_SECRET=replace-with-at-least-32-random-bytes

# Credential encryption: openssl rand -base64 32
AI_CREDENTIAL_ENCRYPTION_KEY=

# Built-in provider chain: Vertex -> OpenAI -> Groq
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
VERTEX_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OpenRouter gateway (disabled when unset)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Agent persistence; URL-encode credentials
AGNO_DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:4000/vio_database
VIO_INTERNAL_API_URL=http://host.docker.internal:3000

# Execution mode. "inline" runs work in the application container.
EVALUATION_EXECUTION_MODE=inline

# Optional integrations
TAVILY_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_TTS_API_KEY=
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=
